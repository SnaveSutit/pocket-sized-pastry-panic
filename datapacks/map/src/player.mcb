import ./score.mcbt
import ./execute.mcbt

function apply_movement_attributes {
	attribute @s minecraft:movement_speed modifier add pspp:elf_speed 0.5 add_multiplied_base
	attribute @s minecraft:jump_strength modifier add pspp:elf_jump 0.5 add_multiplied_base
}

function remove_movement_attributes {
	attribute @s minecraft:movement_speed modifier remove pspp:elf_speed
	attribute @s minecraft:jump_strength modifier remove pspp:elf_jump
}