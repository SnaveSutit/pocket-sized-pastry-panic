function load minecraft:load {
	scoreboard objectives add <%config.internalScoreboardName%> dummy
}

<%%
	global.root = context.namespace + (context.path.length > 0 ? ':' + context.path.join('/') : '')
	config.interactionsNamespace ??= 'snavesutit'
%%>

REPEAT (['right', 'left']) as direction {
	dir <%direction%>_click {
		advancement trigger {
			"criteria": {
				"player_<%direction%>_clicked_interaction_entity": {
					"trigger": "<%direction === 'right' ? 'minecraft:player_interacted_with_entity' : 'minecraft:player_hurt_entity'%>",
					"conditions": {
						"entity": {
							"entity_type": "minecraft:interaction"
						}
					}
				}
			},
			"rewards": {
				"function": "<%context.namespace + ':' + context.path.join('/')%>/on"
			}
		}

		function on {
			advancement revoke @s only <%context.namespace + ':' + context.path.join('/')%>/trigger
			tag @s add <%config.interactionsNamespace%>.interactions.interacting_player
			execute \
				as @e[type=interaction, tag=<%config.interactionsNamespace%>.interactions.interactable, distance=..8] \
				if data entity @s <%direction === 'right' ? 'interaction' : 'attack'%> \
				run function ./check
			tag @s remove <%config.interactionsNamespace%>.interactions.interacting_player
		}

		function check {
			execute store result score #gametime <%config.internalScoreboardName%> run time query gametime
			execute \
				store result score #timestamp <%config.internalScoreboardName%> \
				run data get entity @s <%direction === 'right' ? 'interaction' : 'attack'%>.timestamp

			# Check that the interaction has a command to run, and
			# if this interaction is from the player being processed.
			scoreboard players set #check <%config.internalScoreboardName%> 0
			execute \
				if score #timestamp <%config.internalScoreboardName%> = #gametime <%config.internalScoreboardName%> \
				if data entity @s data.<%config.interactionsNamespace%>.on_<%direction%>_click \
				store success score #check <%config.internalScoreboardName%> \
				on <%direction === 'right' ? 'target' : 'attacker'%> \
				if entity @s[tag=<%config.interactionsNamespace%>.interactions.interacting_player]

			execute \
				if score #check <%config.internalScoreboardName%> matches 1 \
				run function ./do
		}

		function do {
			scoreboard players set #check <%config.internalScoreboardName%> 0
			block execute { with entity @s data.<%config.interactionsNamespace%>
				$$(on_<%direction%>_click)
				scoreboard players set #check <%config.internalScoreboardName%> 1
			}
			execute if score #check <%config.internalScoreboardName%> matches 0 run tellraw @a [ \
				{text: '', color: red}, \
				{text:'ɪɴᴛᴇʀᴀᴄᴛɪᴏɴꜱ', color:'light_purple'}, \
				{text:'\n(<%global.root%>.mcb)', color:'dark_gray'}, \
				'\n→ ᴇʀʀᴏʀ:\n\sFailed to handle <%direction%> click interaction from ', \
				{selector: '@p[tag=<%config.interactionsNamespace%>.interactions.interacting_player]', color: gold}, \
				':\n\s\sInvalid command: ', \
				{nbt: 'data.<%config.interactionsNamespace%>.on_<%direction%>_click', entity: '@s', color: aqua}, \
				'\n\s\sfrom ', \
				{text: 'data.<%config.interactionsNamespace%>.on_<%direction%>_click ', color: yellow}, \
			]
			# Only remove the interaction if it's consumed.
			data remove entity @s <%direction === 'right' ? 'interaction' : 'attack'%>
		}
	}
}
